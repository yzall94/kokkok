# Turso Database
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Set to "true" when Turso is configured (enables real DB instead of demo mode)
NEXT_PUBLIC_TURSO_CONFIGURED=false

# Stats display calibration
NEXT_PUBLIC_STATS_CAL_A=0
NEXT_PUBLIC_STATS_CAL_B=0

# Solapi SMS (server-side only)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# Site URL (for SMS links)
NEXT_PUBLIC_SITE_URL=https://kokkok-nu.vercel.app

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
